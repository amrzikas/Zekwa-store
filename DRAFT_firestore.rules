rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Review Validation ---
    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'rating', 'comment', 'createdAt', 'userName'])
        && data.keys().size() == 6
        && isValidId(data.productId)
        && data.userId == request.auth.uid
        && data.rating is number
        && data.rating >= 1 && data.rating <= 5
        && data.comment is string
        && data.comment.size() <= 1000
        && data.userName is string
        && data.userName.size() <= 100
        && data.createdAt == request.time;
    }

    // --- Rules ---
    match /reviews/{reviewId} {
      allow read: if true;
      
      allow create: if isSignedIn() 
        && isValidReview(incoming())
        && exists(/databases/$(database)/documents/products/$(incoming().productId));

      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isValidReview(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment', 'updatedAt'])
        && incoming().updatedAt == request.time;

      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Admin only via separate secure process or console
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
